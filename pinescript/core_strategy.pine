//@version=6
strategy("SignalFlow AI - Core Alpha Strategy", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// --- INPUTS ---
rsiLen = input.int(14, "RSI Length")
rsiOverbought = input.int(70, "RSI Overbought")
rsiOversold = input.int(30, "RSI Oversold")
bbLen = input.int(20, "Bollinger Length")
bbMult = input.float(2.0, "Bollinger Mult")

// --- MEAN REVERSION LOGIC ---
[basis, upper, lower] = ta.bb(close, bbLen, bbMult)
rsiVal = ta.rsi(close, rsiLen)

longCondition = ta.crossover(close, lower) and rsiVal < rsiOversold
shortCondition = ta.crossunder(close, upper) and rsiVal > rsiOverbought

// --- SIGNAL EXECUTION ---
if (longCondition)
    strategy.entry("Long Signal", strategy.long, comment="MR-LONG")
    alert("LONG @ " + str.tostring(close), alert.freq_once_per_bar)

if (shortCondition)
    strategy.entry("Short Signal", strategy.short, comment="MR-SHORT")
    alert("SHORT @ " + str.tostring(close), alert.freq_once_per_bar)

// --- VISUALS ---
plot(upper, color=color.red, title="BB Upper")
plot(lower, color=color.green, title="BB Lower")
plotshape(longCondition, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, title="Long Label")
plotshape(shortCondition, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, title="Short Label")
